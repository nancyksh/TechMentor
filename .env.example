# ============================================================
# TechMentor AI — environment template
# Copy this file to .env and fill in real values.
# .env is gitignored; never commit secrets.
# ============================================================

# ---------- LLM ----------
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Alternatives:
# GEMINI_MODEL=gemini-2.5-pro     (slower, smarter)
# GEMINI_MODEL=gemini-2.0-flash   (cheaper, less capable)

# ---------- Embeddings ----------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=./data/embeddings_cache
HF_HOME=./data/hf_cache

# ---------- App ----------
APP_DB_PATH=./data/techmentor.db
APP_LOG_LEVEL=INFO
APP_PORT=8501

# ---------- Feature flags ----------
ENABLE_RETRIEVAL=false
ENABLE_INTERVIEW=true
ENABLE_QUIZ=true
ENABLE_ROADMAP=true
